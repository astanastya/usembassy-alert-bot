# 1) Створи Telegram bot через @BotFather і встав токен сюди
TELEGRAM_BOT_TOKEN=123456789:YOUR_TELEGRAM_BOT_TOKEN

# 2) Напиши своєму боту будь-яке повідомлення, потім відкрий:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# і скопіюй значення message.chat.id сюди
TELEGRAM_CHAT_ID=123456789

# Офіційний RSS для alert-дописів сторінки https://ua.usembassy.gov/category/alert/
RSS_URL=https://ua.usembassy.gov/category/alert/feed/

# Перевірка раз на 10 хвилин. Краще не ставити менше 300 секунд.
CHECK_INTERVAL_SECONDS=600

# Де зберігати вже побачені пости
DB_PATH=data/seen_posts.sqlite3

# false = при першому запуску не присилати старі дописи, тільки нові після запуску
SEND_EXISTING_ON_FIRST_RUN=false

# true = прислати повідомлення, що бот стартував
NOTIFY_ON_START=true
